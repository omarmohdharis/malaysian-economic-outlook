# ── DuckDB warehouse ─────────────────────────────────────────────────────────
# The database is too large for GitHub (>100MB). GitHub Actions rebuilds it
# from scratch on every pipeline run by re-fetching from data.gov.my.
# CDC state survives via parquet snapshots in state/ (committed to git).
warehouse/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── dbt ───────────────────────────────────────────────────────────────────────
transforms/target/
transforms/logs/
transforms/dbt_packages/

# ── Quarto build artefacts ────────────────────────────────────────────────────
# docs/ IS committed — GitHub Pages reads from it
# Only exclude intermediate files Quarto generates during execution
.quarto/
**/*.quarto_ipynb
_freeze/

# ── OS & editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

/.quarto/
